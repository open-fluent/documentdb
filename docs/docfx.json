{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Fluent.DocumentDb/Fluent.DocumentDb.csproj",
            "src/Fluent.DocumentDb.DependencyInjection/Fluent.DocumentDb.DependencyInjection.csproj"
          ],
          "src": "../"
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net10.0",
        "NuGetAudit": "false",
        "RestoreIgnoreFailedSources": "true"
      },
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**",
          "templates/**/node_modules/**",
          "templates/**/README.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "**/images/**",
          "public/**",
          "codesnippet/**",
          "manifest.webmanifest",
          "robots.txt"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      }
    ],
    "xrefService": [
      "https://xref.docs.microsoft.com/query?uid={uid}"
    ],
    "postProcessors": [
      "ExtractSearchIndex"
    ],
    "globalMetadata": {
      "_appTitle": "Fluent.DocumentDb",
      "_appName": "Fluent.DocumentDb",
      "_appFaviconPath": "images/favicon.ico",
      "_appLogoPath": "images/documentdb.png",
      "_enableSearch": true,
      "_appFooter": "<span>Built with <a href=\"https://dotnet.github.io/docfx\" rel=\"noreferrer\">DocFX</a> · © 2026 <a href=\"https://github.com/open-fluent\">Open Fluent</a></span>",
      "_gitContribute": {
        "repo": "https://github.com/open-fluent/documentdb",
        "branch": "main"
      },
      "_gitUrlPattern": "github"
    },
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "markdownEngineName": "markdig",
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false
  }
}
